{
  "framework": null,
  "buildCommand": "cd ../.. && npx turbo build --filter=bookable-online",
  "installCommand": "cd ../.. && npm install",
  "outputDirectory": "dist/client",
  "functions": {
    "api/ssr.ts": {
      "includeFiles": "dist/server/**"
    },
    "api/sitemap.ts": {
      "includeFiles": "src/data/**"
    },
    "api/ai-search-audit.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/api/ai-search-audit", "destination": "/api/ai-search-audit" },
    { "source": "/llms.txt", "destination": "/llms.txt" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/(.*)", "destination": "/api/ssr" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
