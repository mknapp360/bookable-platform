{
  "name": "bookable",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*",
    "clients/*",
    "apps/*"
  ],
  "scripts": {
    "dev:crm":         "npm run dev --workspace=@bookable/crm-core",
    "dev:wilkinson":   "turbo dev --filter=wilkinson-er",
    "dev:admin":       "npm run dev --workspace=wilkinson-admin",
    "build":           "turbo build",
    "build:crm":       "npm run build --workspace=@bookable/crm-core",
    "build:wilkinson": "turbo build --filter=wilkinson-er",
    "dev:therayan":    "turbo dev --filter=therayan-partners",
    "build:therayan":  "turbo build --filter=therayan-partners",
    "dev:saas":        "turbo dev --filter=bookable-saas",
    "build:saas":      "turbo build --filter=bookable-saas",
    "dev:gc":          "turbo dev --filter=genuine-connections",
    "build:gc":        "turbo build --filter=genuine-connections",
    "dev:online":      "turbo dev --filter=bookable-online",
    "build:online":    "turbo build --filter=bookable-online"
  },
  "packageManager": "npm@11.6.2",
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
